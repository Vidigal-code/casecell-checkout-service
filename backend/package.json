{
  "name": "casecell-backend",
  "version": "1.0.0",
  "description": "CaseCellShop checkout backend service",
  "license": "MIT",
  "scripts": {
    "build": "npm run prisma:generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "prisma:generate": "node scripts/run-with-env.js npx prisma generate",
    "prisma:migrate": "node scripts/run-with-env.js npx prisma migrate dev",
    "prisma:deploy": "node scripts/run-with-env.js npx prisma migrate deploy",
    "prisma:seed": "node scripts/run-with-env.js npx ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed.ts",
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.ts",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:e2e": "jest --config jest.e2e.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.2",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/platform-express": "^10.3.2",
    "@nestjs/schedule": "^3.0.4",
    "@prisma/client": "^5.11.0",
    "@sinclair/typebox": "^0.32.25",
    "argon2": "^0.31.2",
    "swagger-ui-express": "^5.0.0",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "bullmq": "^4.17.0",
    "cache-manager": "^5.4.0",
    "prom-client": "^15.1.2",
    "@nestjs/throttler": "^5.1.2",
    "@opentelemetry/api": "^1.8.0",
    "cache-manager-ioredis-yet": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "ioredis": "^5.3.2",
    "nestjs-pino": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.0.1",
    "@nestjs/testing": "^10.3.2",
    "@prisma/adapter-pg": "^5.11.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/passport-jwt": "^3.0.10",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "pg-mem": "^2.1.6",
    "prettier": "^3.2.5",
    "pino-pretty": "^10.3.1",
    "prisma": "^5.11.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3"
  }
}
