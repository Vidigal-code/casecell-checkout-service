NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://casecell:casecell@localhost:5432/casecell
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_ACCESS_TOKEN_SECRET=supersecretjwtkey
JWT_ACCESS_TOKEN_EXPIRES_IN=900s
JWT_REFRESH_TOKEN_SECRET=supersecretrefreshkey
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
ERP_SIMULATION_FAILURE_RATE=0.3
ERP_SIMULATION_MIN_DELAY_MS=800
ERP_SIMULATION_MAX_DELAY_MS=2500
IDEMPOTENCY_TTL_SECONDS=600
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=30
PRODUCTS_CACHE_TTL_SECONDS=60
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/api.log
LOG_ROTATION_WHEN=midnight
LOG_BACKUP_COUNT=7
